# Environment Configuration Template
# Copy this file to .env.local and fill in your values

# ================================
# APPLICATION SETTINGS
# ================================

# Application environment (development, staging, production)
NODE_ENV=development

# ================================
# API CONFIGURATION
# ================================

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# WebSocket URL for real-time features
NEXT_PUBLIC_WS_URL=ws://localhost:5000

# Use mock API instead of real backend (true/false)
# Set to 'true' during initial development when backend is not ready
# Set to 'false' when integrating with real backend
NEXT_PUBLIC_USE_MOCK=true

# ================================
# AUTHENTICATION
# ================================

# Google OAuth Client ID (for Google Sign-In)
# Get from: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here

# OAuth Redirect URI
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ================================
# FEATURE FLAGS
# ================================

# Enable/disable features (true/false)
NEXT_PUBLIC_ENABLE_MESSAGING=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_PREMIUM=false

# ================================
# THIRD-PARTY SERVICES
# ================================

# Sentry DSN for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=

# Analytics tracking ID (Google Analytics, etc.)
# NEXT_PUBLIC_ANALYTICS_ID=

# ================================
# MEDIA CONFIGURATION
# ================================

# Maximum file upload size (in MB)
NEXT_PUBLIC_MAX_FILE_SIZE=50

# Allowed audio formats
NEXT_PUBLIC_ALLOWED_FORMATS=mp3,wav,flac

# ================================
# APPLICATION LIMITS
# ================================

# Pagination defaults
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20
NEXT_PUBLIC_MAX_PAGE_SIZE=100

# ================================
# DEVELOPMENT TOOLS
# ================================

# Enable React Query DevTools
NEXT_PUBLIC_ENABLE_REACT_QUERY_DEVTOOLS=true


# ================================
# NOTES
# ================================

# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Private variables (without NEXT_PUBLIC_) are only available server-side
# - Never commit .env.local to version control
# - Update this template when adding new environment variables
